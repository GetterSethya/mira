{
  "compilerOptions": {
    "target":              "ES2022",
    "module":              "NodeNext",
    "moduleResolution":    "NodeNext",
    "lib":                 ["ES2022"],
    "outDir":              "dist",
    "strict":              true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations":  "6.0",
    "skipLibCheck":        true,
    "types":               ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}

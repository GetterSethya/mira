{
  "compilerOptions": {
    "target":              "ES2022",
    "module":              "NodeNext",
    "moduleResolution":    "NodeNext",
    "lib":                 ["ES2022"],
    "outDir":              "dist",
    "strict":              true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations":  "6.0",
    "skipLibCheck":        true,
    "types":               ["node"],
    "paths": {
      "@gettersethya/mira":        ["../../packages/mira/dist/src/index.d.ts"],
      "@gettersethya/mira-client": ["../../packages/client/dist/src/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}

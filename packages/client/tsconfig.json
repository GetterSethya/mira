{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "NodeNext",
    "moduleResolution":           "NodeNext",
    "lib":                        ["ES2022", "DOM"],
    "types":                      ["node"],
    "outDir":                     "dist",
    "baseUrl":                    ".",
    "paths": {
      "@/*": ["src/*"],
      "@gettersethya/mira-collection": ["../collection/dist/src/index.d.ts"]
    },
    "strict":                     true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations":         "6.0",
    "skipLibCheck":               true,
    "declaration":                true,
    "declarationMap":             true,
    "sourceMap":                  true,
    "composite":                  true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["effect"]
      }
    ]
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}

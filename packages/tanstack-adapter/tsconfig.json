{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "outDir":           "dist",
    "baseUrl":          ".",
    "paths": {
      "@gettersethya/mira-client": ["../client/dist/src/index.d.ts"]
    },
    "ignoreDeprecations": "6.0",
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "strict":           true,
    "skipLibCheck":     true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist", "src/react.ts", "src/svelte.ts", "src/solid.ts"]
}

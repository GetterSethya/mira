{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@gettersethya/mira": ["../mira/dist/src/index.d.ts"],
      "@gettersethya/mira-client": ["../client/dist/src/index.d.ts"]
    },
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "ui"]
}

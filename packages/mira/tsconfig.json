{
  "compilerOptions": {
    "target":                     "ES2022",
    "module":                     "NodeNext",
    "moduleResolution":           "NodeNext",
    "lib":                        ["ES2022"],
    "outDir":                     "dist",
    "baseUrl":                    ".",
    "paths": {
      "@/*":                  ["src/*"],
      "@gettersethya/mira-client":  ["../client/dist/src/index.d.ts"]
    },
    "strict":                     true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations":         "6.0",
    "skipLibCheck":               true,
    "declaration":                true,
    "declarationMap":             true,
    "sourceMap":                  true,
    "types":                      ["node"],
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": [
          "effect",
          "@effect/platform",
          "@effect/platform-node",
          "@effect/sql",
          "@effect/sql-sqlite-node"
        ]
      }
    ]
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
